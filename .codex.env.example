# Copy to .codex.env and adjust for your machine.

# Moodle checkout (mounted into containers by moodle-docker).
MOODLE_DIR="$HOME/projects/moodle"

# moodle-docker checkout with bin/moodle-docker-compose.
MOODLE_DOCKER_DIR="$HOME/projects/moodle-docker"

# docker compose service that runs php cli commands.
WEBSERVER_SERVICE="webserver"

# User to run Behat cli commands as.
WEBSERVER_USER="www-data"

# Optional binary overrides (defaults usually work).
# PHPUNIT_BIN="vendor/bin/phpunit"
# PHPCS_BIN="vendor/bin/phpcs"
# PHPCBF_BIN="vendor/bin/phpcbf"

# Optional install defaults used by ./codex/install
# SITE_FULLNAME="Moodle Master"
# SITE_SHORTNAME="docker_moodle"
# SITE_SUMMARY="Moodle dev site"
# ADMIN_USER="admin"
# ADMIN_PASS="test"
# ADMIN_EMAIL="admin@example.com"
