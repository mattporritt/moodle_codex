#!/usr/bin/env bash
set -euo pipefail

# Resolve paths relative to this script:
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MDOCKER_BIN="${ROOT_DIR}/moodle-docker/bin"

if [[ ! -x "${MDOCKER_BIN}/moodle-docker-compose" ]]; then
  echo "ERROR: Can't find executable moodle-docker-compose at:"
  echo "  ${MDOCKER_BIN}/moodle-docker-compose"
  echo ""
  echo "Expected structure:"
  echo "  <repo>/moodle-docker/bin/moodle-docker-compose"
  exit 1
fi

cd "${MDOCKER_BIN}"
exec ./moodle-docker-compose "$@"
