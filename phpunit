#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   ./codex/phpunit                (all)
#   ./codex/phpunit path/to/test.php
ARGS=("$@")

if [[ ${#ARGS[@]} -eq 0 ]]; then
  "$(dirname "$0")/mdc" exec webserver vendor/bin/phpunit
else
  "$(dirname "$0")/mdc" exec webserver vendor/bin/phpunit "${ARGS[@]}"
fi
